# Обов'язково: створіть бота через @BotFather.
TELEGRAM_BOT_TOKEN=

# Обов'язково: ключ BigModel / Zhipu AI.
ZAI_API_KEY=
ZAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
ZAI_TEXT_MODEL=glm-4.7-flash
ZAI_VISION_MODEL=glm-4.6v-flash
ZAI_TIMEOUT_SECONDS=45

# Локальний SQLite зберігає всі дані (користувачі, категорії, чернетки, операції).
DATABASE_PATH=./data/finance_bot.sqlite3
APP_TIMEZONE=Europe/Kyiv

# Через кому, без пробілів. Порожньо = дозволити всім Telegram-користувачам.
ALLOWED_TELEGRAM_USER_IDS=

DRAFT_TTL_SECONDS=900
DUPLICATE_WINDOW_SECONDS=30
MAX_IMAGE_BYTES=5242880
LOG_LEVEL=INFO